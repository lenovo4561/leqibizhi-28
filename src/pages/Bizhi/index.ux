  color: #ffffff;
  font-weight: 700;
}

/* 4个分类 */
.category-grid {
  flex-wrap: wrap;
  justify-content: space-between;
}

.cat-item {
  width: 110px;
  height: 68px;
  border-radius: 8px;
  margin-bottom: 6px;
  background-color: #dfdfdf;
  position: relative;
  overflow: hidden;
}

