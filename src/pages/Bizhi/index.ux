  align-items: center;
  margin-bottom: 12px;
}

.hot-title {
  font-size: 15px;
  font-weight: 700;
  color: #222222;
}

.refresh-wrap {
  flex-direction: row;
  align-items: center;
}

.refresh-icon {
  width: 14px;
