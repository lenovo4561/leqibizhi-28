<template>
  <div class="webview-container">
    <web class="webview" src="{{url}}"></web>
  </div>
</template>

<script>
export default {
  data() {
    return {
      title: '',
      url: ''
    }
  },

  onInit() {
    if (this.title) {
      this.$page.setTitleBar({ text: this.title })
    }
  }
}
</script>

<style>
.webview-container {
  flex: 1;
  width: 100%;
  height: 100%;
  flex-direction: column;
}

.webview {
  flex: 1;
  width: 100%;
  height: 100%;
}
</style>
